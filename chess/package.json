{
  "name": "chess-pwa",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "copy-stockfish": "node -e \"const {copyFileSync,mkdirSync,existsSync}=require('fs');mkdirSync('public/stockfish',{recursive:true});['stockfish-nnue-16-single.js','stockfish-nnue-16-single.wasm'].forEach(f=>{const src='node_modules/stockfish/src/'+f;if(existsSync(src))copyFileSync(src,'public/stockfish/'+f);else console.warn('NOT FOUND:',src)})\"",
    "prebuild": "npm run copy-stockfish",
    "predev": "npm run copy-stockfish"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-chessboard": "^4.7.3",
    "react-router-dom": "^6.30.0",
    "recharts": "^2.15.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "stockfish": "^16.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^0.21.1",
    "workbox-window": "^7.4.1"
  }
}
